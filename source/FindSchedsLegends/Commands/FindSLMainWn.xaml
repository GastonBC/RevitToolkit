<Window x:Class="FindSchedsLegends.FindSLMainWn"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FindSchedsLegends"
        mc:Ignorable="d"
        Title="Find Schedules/Legends" MinHeight="500" MinWidth="400" Height="510" Width="580"
        Topmost="True">
    <Grid Margin="10,10,10,10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="30"/>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="50"/>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="90"/>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="10"/>
            <RowDefinition/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>

        <Button x:Name="ClearSearch_Copy" Content="✖" Foreground="Gray" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" IsEnabled="True" Click="ClearSearch_Click" Grid.RowSpan="1"/>

        <TextBox x:Name="Search_tb" VerticalContentAlignment="Center" TextChanged="search_txt_changed" Grid.Column="2" Grid.ColumnSpan="7" />
        <TextBlock IsHitTestVisible="False" Text="  Sheet number or name" Margin="0,6,0,0" Foreground="DarkGray" Grid.Column="2" Grid.ColumnSpan="7">
            <TextBlock.Style>
                <Style TargetType="{x:Type TextBlock}">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Text, ElementName=Search_tb}" Value="">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <ListView x:Name="SLListView" SelectionMode="Extended" SelectionChanged="onSelectionChange" Grid.ColumnSpan="7" Grid.Row="2">
            <ListView.View>
                <GridView>
                    <GridViewColumn Width="100" DisplayMemberBinding="{Binding Type}">
                        <GridViewColumn.Header>
                            <GridViewColumnHeader Tag="Type" Click="ColHeader_Click">Type</GridViewColumnHeader>
                        </GridViewColumn.Header>
                    </GridViewColumn>

                    <GridViewColumn Width="200" DisplayMemberBinding="{Binding Name}">
                        <GridViewColumn.Header>
                            <GridViewColumnHeader Tag="Name" Click="ColHeader_Click">Name</GridViewColumnHeader>
                        </GridViewColumn.Header>
                    </GridViewColumn>

                    <GridViewColumn Width="120" DisplayMemberBinding="{Binding ElemCount}">
                        <GridViewColumn.Header>
                            <GridViewColumnHeader Tag="ElemCount" Click="ColHeader_Click">Sheet count</GridViewColumnHeader>
                        </GridViewColumn.Header>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>
        <Button x:Name="b_ViewSheetGUI" Content="View sheets" Grid.Row="4" Margin="0,0,0,0" IsEnabled="False" Click="b_GoSheetGUI_Click" Grid.ColumnSpan="3"/>
        <Button x:Name="b_Select" Content="Select" Grid.Row="4" Click="b_Select_Click" IsEnabled="False" Grid.Column="4"/>
        <Label x:Name="TextLab" Grid.Row="4" Grid.Column="6" Grid.ColumnSpan="3"/>

    </Grid>
</Window>