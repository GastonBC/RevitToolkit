<Window x:Class="Toolbox.TemplateReplace.SecondWn"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Toolbox.TemplateReplace"
        mc:Ignorable="d"
        Title="Replace Templates" MinHeight="500" MinWidth="400" Height="500" Width="500"
        Topmost="True" ShowInTaskbar="False">
    <Grid Margin="10,10,10,10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="30"/>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="60"/>
            <ColumnDefinition/>
            <ColumnDefinition Width="100"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="10"/>
            <RowDefinition/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>

        <Button x:Name="ClearSearch_Copy" Content="✖" Foreground="Gray" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" IsEnabled="True" Click="ClearSearch_Click" Grid.RowSpan="1"/>

        <TextBox x:Name="Search_tb" VerticalContentAlignment="Center" TextChanged="search_txt_changed" Grid.Column="2" Grid.ColumnSpan="3" />
        <TextBlock IsHitTestVisible="False" Text="  Sheet number or name" Margin="0,6,0,0" Foreground="DarkGray" Grid.Column="2" Grid.ColumnSpan="3">
            <TextBlock.Style>
                <Style TargetType="{x:Type TextBlock}">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Text, ElementName=Search_tb}" Value="">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <ListView x:Name="Templates_lv" SelectionMode="Single" Grid.Row="2" Grid.ColumnSpan="5" SelectionChanged="onSelectionChange">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="View Template" DisplayMemberBinding="{Binding Name}" Width="260" />
                    <GridViewColumn Header="Type" DisplayMemberBinding="{Binding ViewType}" Width="150" />
                </GridView>
            </ListView.View>
        </ListView>
        <Button x:Name="b_Select" Content="Select" Grid.Row="4" Click="b_Select_Click" IsEnabled="False" Grid.ColumnSpan="3"/>
        <Label x:Name="TextLab" Grid.Row="4" Grid.Column="3" Margin="110,0,0,0"/>

    </Grid>
</Window>