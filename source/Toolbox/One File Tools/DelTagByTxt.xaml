<Window x:Class="Toolbox.One_file_tools.DelTagByTxt"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Topmost="true" Title="Delete tags" Width="350" Height="130" ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual"
        Background="#FFFAFAFB">
    <Grid Margin="10">

        <StackPanel  Grid.RowSpan="3">
            <TextBox x:Name="SetNameBox" Height="30" IsHitTestVisible="true" HorizontalContentAlignment="Center"
             VerticalContentAlignment="Center" TextWrapping="Wrap" Text="x" FontSize="16"
             FontFamily="Arial Rounded MT Bold" Background="#FFFAFAFA"/>

            <Border  Height="10"/>

            <Button Click="Create_Click" x:Name="SetButton" Height="30" Content="Delete" Grid.Row="8"/>

        </StackPanel>
    </Grid>
</Window>