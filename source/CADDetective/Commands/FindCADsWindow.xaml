<Window x:Class="CADDetective.FindCADsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CADDetective"
        mc:Ignorable="d"
        Title="CAD Detective" MinHeight="500" MinWidth="400" Height="510" Width="580"
        Topmost="True" ShowInTaskbar="False">
    <Grid Margin="10,10,10,10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="30"/>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="50"/>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="90"/>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="90"/>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="10"/>
            <RowDefinition/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>

        <Button x:Name="ClearSearch_Copy" Content="✖" Foreground="Gray" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" IsEnabled="True" Click="ClearSearch_Click" Grid.RowSpan="1"/>

        <TextBox x:Name="Search_tb" VerticalContentAlignment="Center" TextChanged="search_txt_changed" Grid.Column="2" Grid.ColumnSpan="7" />
        <TextBlock IsHitTestVisible="False" Text="  Sheet number or name" Margin="0,6,0,0" Foreground="DarkGray" Grid.Column="2" Grid.ColumnSpan="7">
            <TextBlock.Style>
                <Style TargetType="{x:Type TextBlock}">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Text, ElementName=Search_tb}" Value="">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <ListView x:Name="CADListView" SelectionMode="Extended" Grid.Row="2" Grid.ColumnSpan="9">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox Margin="3, 0" IsChecked="{Binding Path=Checked, Mode=TwoWay}" Checked="onCheckBoxCheck" Unchecked="onCheckBoxUncheck"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="CAD Name" DisplayMemberBinding="{Binding CADImportInstance.Category.Name}" Width="200" />
                    <GridViewColumn Header="View Specific" DisplayMemberBinding="{Binding ViewName}" Width="100" />
                    <GridViewColumn Header="Is linked" DisplayMemberBinding="{Binding CADImportInstance.IsLinked}" Width="100" />
                    <GridViewColumn Header="Manual hide" DisplayMemberBinding="{Binding IsHide}" Width="100" />
                </GridView>
            </ListView.View>
        </ListView>
        <Button x:Name="GoCAD" Content="Go to CAD" Grid.Row="4" Click="GoCAD_Click" IsEnabled="False" Grid.ColumnSpan="3"/>
        <Button x:Name="SelCAD" Content="Select CAD" Grid.Row="4" Click="SelectCAD_Click" IsEnabled="False" Grid.Column="4"/>
        <Button x:Name="GoView" Content="Go to View" Grid.Row="4" Click="GoView_Click" IsEnabled="False" Grid.Column="6"/>
        <Label Content="Fields in blank are non-view-specific CADs" Grid.Row="4" Grid.Column="8"/>

    </Grid>
</Window>